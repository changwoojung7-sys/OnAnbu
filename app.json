{
  "expo": {
    "name": "ONANBU",
    "slug": "on-anbu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon_v2.png",
    "scheme": "onanbu",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onanbu.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F5F5F0"
      },
      "package": "com.onanbu.app",
      "versionCode": 4
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-2810872681064029~9505790008",
          "iosAppId": "ca-app-pub-2810872681064029~9505790008"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "4d09e18a-0eb8-472d-a9f3-cc74d48fdc02"
      }
    },
    "owner": "calamus7",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/4d09e18a-0eb8-472d-a9f3-cc74d48fdc02"
    }
  }
}
